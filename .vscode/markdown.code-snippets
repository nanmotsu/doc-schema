    },
    "table": {
        "prefix": "tbl",
        "description": "表（キャプション付き）",
        "body": [
            ":::table",
            "${1:表タイトル}",
            "",
            "| ${2:列1} | ${3:列2} |",
            "| --- | --- |",
            "| ${4:} | ${5:} |",
            ":::"
        ],
        "scope": "markdown"
    }
