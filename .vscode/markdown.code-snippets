    "figure": {
        "prefix": "fig",
        "description": "図（キャプション付き・internal起点）",
        "body": [
            ":::figure ${4:width=80%} origin=internal",
            "![${1:alt}](${2:path})",
            "",
            "${3:キャプション}",
            ":::"
        ],
        "scope": "markdown"
    },
    "figure_ext": {
        "prefix": "fige",
        "description": "図（キャプション付き・external起点）",
        "body": [
