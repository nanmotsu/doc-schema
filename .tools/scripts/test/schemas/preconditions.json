{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "preconditions.yaml スキーマ",
    "description": "全テスト共通の前提条件ファイル（preconditions.yaml）",
    "type": "object",
    "required": ["preconditions"],
    "additionalProperties": false,
    "properties": {
        "preconditions": {
            "type": "array",
            "description": "全テスト共通の前提条件リスト",
            "minItems": 1,
            "items": { "type": "string" }
        },
        "environment": {
            "type": "object",
            "description": "実行環境。省略可。項目は任意",
            "properties": {
                "os":      { "type": "string" },
                "browser": { "type": "string" },
                "server":  { "type": "string" },
                "db":      { "type": "string" }
            }
        },
        "test_data": {
            "$ref": "#/$defs/test_data_array"
        }
    },
    "$defs": {
        "test_data_array": {
            "type": "array",
            "description": "事前データ定義。省略可",
            "items": {
                "type": "object",
                "required": ["label", "columns", "rows"],
                "additionalProperties": false,
                "properties": {
                    "label":       { "type": "string", "description": "データセット名（Excelの表タイトル）" },
                    "description": { "type": "string", "description": "補足説明。省略可" },
                    "columns":     { "type": "array", "minItems": 1, "items": { "type": "string" } },
                    "rows": {
                        "type": "array",
                        "description": "データ行の配列（各行も配列）",
                        "items": { "type": "array" }
                    }
                }
            }
        }
    }
}
