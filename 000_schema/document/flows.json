{
    "flows": [
        {
            "key": "new_development",
            "label": "新規開発",
            "description": "要望・企画から始まる新規機能開発",
            "when": "アイデアや要望が起点。外部仕様から内部設計まで一通り揃える場合。",
            "steps": [
                "source",
                "issue",
                "decision",
                "requirement",
                "spec_external",
                "spec_internal",
                "task_impl"
            ]
        },
        {
            "key": "customer_requirement",
            "label": "顧客要件が最初からある",
            "description": "顧客から要件が提示された場合の開発",
            "when": "客先から仕様書や要望書が届いた場合。要件の矛盾・不足を整理してから進める。",
            "steps": [
                "source",
                "requirement",
                "issue",
                "decision",
                "spec_external",
                "spec_internal",
                "task_impl"
            ]
        },
        {
            "key": "existing_modification",
            "label": "既存機能の改修",
            "description": "既存機能の改善・修正",
            "when": "バグ修正、仕様変更、リファクタリングなど既存コードへの変更が起点の場合。",
            "steps": [
                "source",
                "issue",
                "decision",
                "requirement",
                "spec_internal",
                "task_impl"
            ]
        },
        {
            "key": "quick_task",
            "label": "小さな作業（タスクのみ）",
            "description": "調査・検討不要な軽微な作業",
            "when": "内容が自明で設計・要件整理が不要な場合。ドキュメントを増やしたくないとき。",
            "steps": [
                "source",
                "task_impl"
            ]
        }
    ]
}
