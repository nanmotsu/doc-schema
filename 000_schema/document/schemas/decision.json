{
    "key": "decision",
    "label": "Decision（決定）",
    "prefix": "DEC",
    "idExample": "DEC-001",
    "dirParts": [ "internal", "2_decisions" ],
    "numbering": "seq",
    "defaultStatus": "DRAFT",
    "statuses": [
        { "code": "UNFINISHED", "label": "未整理" },
        { "code": "DRAFT", "label": "検討中" },
        { "code": "ACTIVE", "label": "採用決定" },
        { "code": "SUPERSEDED", "label": "置き換え済み" },
        { "code": "DEPRECATED", "label": "廃止" }
    ],
    "schema": {
        "required": [ "id", "status" ],
        "properties": {
            "id": { "type": "string", "pattern": "^DEC-\\d{3}$" },
            "status": { "type": "string", "enum": [ "UNFINISHED", "DRAFT", "ACTIVE", "SUPERSEDED", "DEPRECATED" ] },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "tags:",
        "  - DEC",
        "status: {{status}}",
        "updated_at: {{date}}",
        "---",
        "",
        "# {{id}}_{{title}}",
        "",
        "## 内容",
        "- 決定内容:",
        "",
        "## 理由",
        "- ",
        "",
        "## 代替案",
        "- 案A:",
        "- 案B:",
        "",
        "## 影響",
        "- ",
        "",
        "## 関連リンク",
        "- ",
        ""
    ]
}
