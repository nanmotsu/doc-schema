{
    "key": "decision",
    "label": "Decision",
    "prefix": "DEC",
    "idExample": "DEC-2026-001",
    "dirParts": [ "docs", "10_specs", "decisions" ],
    "numbering": "year_seq",
    "defaultStatus": "approved",
    "statuses": [
        { "code": "draft", "label": "draft" },
        { "code": "review", "label": "review" },
        { "code": "approved", "label": "approved" },
        { "code": "active", "label": "active" },
        { "code": "deprecated", "label": "deprecated" },
        { "code": "closed", "label": "closed" }
    ],
    "schema": {
        "required": [ "id", "title", "type", "status", "visibility" ],
        "properties": {
            "id": { "type": "string", "pattern": "^DEC-\\d{4}-\\d{3}$" },
            "title": { "type": "string" },
            "type": { "type": "string", "enum": [ "decision" ] },
            "status": { "type": "string", "enum": [ "draft", "review", "approved", "active", "deprecated", "closed" ] },
            "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "owner": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "requirements": { "type": "array", "items": { "type": "string", "pattern": "^(\\[\\[[^\\]\\n]+\\]\\]|REQ-\\d{4}-\\d{3})$" } },
            "visibility": { "type": "string", "enum": [ "internal", "customer", "partial", "confidential" ] }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "title: {{title}}",
        "type: decision",
        "status: {{status}}",
        "created_at: {{date}}",
        "updated_at: {{date}}",
        "owner:",
        "tags:",
        "  - ",
        "requirements:",
        "  - ",
        "visibility: internal",
        "---",
        "",
        "# {{id}}_{{title}}",
        "",
        "## 1. 決定内容",
        "- 何を採用するか",
        "",
        "## 2. 決定理由",
        "- なぜその案にしたか",
        "",
        "## 3. 採用案",
        "- 実施する具体案",
        "",
        "## 4. 不採用案と理由",
        "- 代替案があれば書く",
        "",
        "## 5. 影響範囲",
        "- 仕様 / 運用 / 顧客 / 監査への影響",
        "",
        "## 6. 関連リンク",
        "- Issue / Requirement / Specification など",
        ""
    ]
}
