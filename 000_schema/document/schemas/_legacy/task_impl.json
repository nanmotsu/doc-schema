{
    "key": "task_impl",
    "label": "TASK（実装タスク）",
    "prefix": "TASK",
    "idExample": "TASK-001",
    "dirParts": [ "internal", "3_tasks" ],
    "numbering": "seq",
    "defaultStatus": "UNFINISHED",
    "statuses": [
        { "code": "UNFINISHED", "label": "未整理" },
        { "code": "TODO", "label": "未着手" },
        { "code": "DOING", "label": "作業中" },
        { "code": "BLOCKED", "label": "停止中" },
        { "code": "DONE", "label": "完了" },
        { "code": "CANCELLED", "label": "中止" }
    ],
    "schema": {
        "required": [ "id", "status" ],
        "properties": {
            "id": { "type": "string", "pattern": "^TASK-\\d{3}$" },
            "status": { "type": "string", "enum": [ "UNFINISHED", "TODO", "DOING", "BLOCKED", "DONE", "CANCELLED" ] },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "tags:",
        "  - TASK",
        "status: {{status}}",
        "updated_at: {{date}}",
        "---",
        "",
        "# {{id}}_{{title}}",
        "",
        "## 内容",
        "- ",
        "",
        "## 作業内容",
        "- ",
        "",
        "## 関連リンク",
        "- ",
        ""
    ]
}
