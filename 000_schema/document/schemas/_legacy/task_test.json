{
    "key": "task_test",
    "label": "TEST（テストタスク）",
    "prefix": "TEST",
    "idExample": "TEST-001",
    "dirParts": [ "internal", "7_test" ],
    "numbering": "seq",
    "defaultStatus": "UNFINISHED",
    "statuses": [
        { "code": "UNFINISHED", "label": "未整理" },
        { "code": "DRAFT", "label": "作成中" },
        { "code": "READY", "label": "実行可能" },
        { "code": "PASSED", "label": "成功" },
        { "code": "FAILED", "label": "失敗" },
        { "code": "DEPRECATED", "label": "廃止" }
    ],
    "schema": {
        "required": [ "id", "status" ],
        "properties": {
            "id": { "type": "string", "pattern": "^TEST-\\d{3}$" },
            "status": { "type": "string", "enum": [ "UNFINISHED", "DRAFT", "READY", "PASSED", "FAILED", "DEPRECATED" ] },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "tags:",
        "  - TEST",
        "status: {{status}}",
        "updated_at: {{date}}",
        "---",
        "",
        "# {{id}}_{{title}}",
        "",
        "## テスト内容",
        "- ",
        "",
        "## 前提条件",
        "- ",
        "",
        "## 手順",
        "1. ",
        "2. ",
        "",
        "## 期待結果",
        "- ",
        "",
        "## 関連リンク",
        "- ",
        ""
    ]
}
