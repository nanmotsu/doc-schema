{
    "key": "change_level2",
    "label": "Lv2 Change",
    "prefix": "CHG",
    "idExample": "CHG-2026-001",
    "dirParts": [ "docs", "10_specs", "changes", "level2_changes" ],
    "numbering": "year_seq",
    "defaultStatus": "draft",
    "statuses": [
        { "code": "draft", "label": "draft" },
        { "code": "review", "label": "review" },
        { "code": "approved", "label": "approved" },
        { "code": "active", "label": "active" },
        { "code": "deprecated", "label": "deprecated" },
        { "code": "closed", "label": "closed" }
    ],
    "schema": {
        "required": [ "id", "title", "type", "level", "status", "visibility" ],
        "properties": {
            "id": { "type": "string", "pattern": "^CHG-\\d{4}-\\d{3}$" },
            "title": { "type": "string" },
            "type": { "type": "string", "enum": [ "change" ] },
            "level": { "type": "integer", "enum": [ 2 ] },
            "status": { "type": "string", "enum": [ "draft", "review", "approved", "active", "deprecated", "closed" ] },
            "version": { "type": "string" },
            "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "owner": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "specifications": { "type": "array", "items": { "type": "string", "pattern": "^(\\[\\[[^\\]\\n]+\\]\\]|SPEC-\\d{4}-\\d{3})$" } },
            "releases": { "type": "array", "items": { "type": "string", "pattern": "^(\\[\\[[^\\]\\n]+\\]\\]|RELEASE-\\d{4}-\\d{3})$" } },
            "visibility": { "type": "string", "enum": [ "internal", "customer", "partial", "confidential" ] }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "title: {{title}}",
        "type: change",
        "level: 2",
        "status: {{status}}",
        "version: 0.1.0",
        "created_at: {{date}}",
        "updated_at: {{date}}",
        "owner:",
        "tags:",
        "  - ",
        "specifications:",
        "  - ",
        "releases:",
        "  - ",
        "visibility: internal",
        "---",
        "",
        "# 変更名",
        "",
        "## 1. 背景",
        "",
        "## 2. 変更理由",
        "",
        "## 3. 変更内容",
        "",
        "## 4. 影響範囲",
        "",
        "| 区分 | 影響有無 | 内容 |",
        "|---|---|---|",
        "| 画面 |  |  |",
        "| API |  |  |",
        "| DB |  |  |",
        "| バッチ |  |  |",
        "| 権限 |  |  |",
        "| 運用 |  |  |",
        "| マニュアル |  |  |",
        "| 客先成果物 |  |  |",
        "",
        "## 5. 関連仕様",
        "",
        "## 6. テスト方針",
        "",
        "## 7. 回帰確認",
        "",
        "## 8. リリース時の注意",
        ""
    ]
}
