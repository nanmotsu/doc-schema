{
    "key": "issue",
    "label": "Issue",
    "prefix": "ISSUE",
    "idExample": "ISSUE-2026-001",
    "dirParts": [ "docs", "10_specs", "issues" ],
    "numbering": "year_seq",
    "defaultStatus": "draft",
    "statuses": [
        { "code": "draft", "label": "draft" },
        { "code": "review", "label": "review" },
        { "code": "approved", "label": "approved" },
        { "code": "active", "label": "active" },
        { "code": "deprecated", "label": "deprecated" },
        { "code": "closed", "label": "closed" }
    ],
    "schema": {
        "required": [ "id", "title", "type", "status", "visibility" ],
        "properties": {
            "id": { "type": "string", "pattern": "^ISSUE-\\d{4}-\\d{3}$" },
            "title": { "type": "string" },
            "type": { "type": "string", "enum": [ "issue" ] },
            "status": { "type": "string", "enum": [ "draft", "review", "approved", "active", "deprecated", "closed" ] },
            "priority": { "type": "string" },
            "severity": { "type": "string" },
            "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "owner": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "decisions": { "type": "array", "items": { "type": "string", "pattern": "^(\\[\\[[^\\]\\n]+\\]\\]|DEC-\\d{4}-\\d{3})$" } },
            "visibility": { "type": "string", "enum": [ "internal", "customer", "partial", "confidential" ] }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "title: {{title}}",
        "type: issue",
        "status: {{status}}",
        "priority:",
        "severity:",
        "created_at: {{date}}",
        "updated_at: {{date}}",
        "owner:",
        "tags:",
        "  - ",
        "decisions:",
        "  - ",
        "visibility: internal",
        "---",
        "",
        "# {{id}}_{{title}}",
        "",
        "## 1. 発生元",
        "- 会議 / 問い合わせ / 障害 / 要望 など",
        "",
        "## 2. 内容",
        "- 何が問題かを 1 文で書く",
        "",
        "## 3. 背景",
        "- なぜ今これを扱うのか",
        "",
        "## 4. 影響",
        "- 人 / 機能 / 画面 / 運用 / 顧客影響",
        "",
        "## 5. 調査結果",
        "- 事実と未確認事項を分けて書く",
        "",
        "## 6. 選択肢",
        "- 採用案 / 保留案 / 却下案",
        "",
        "## 7. 決定待ち事項",
        "- 決めるべきことを箇条書きにする",
        "",
        "## 8. 次アクション",
        "- Decision 作成 / 追加調査 / 仕様化 など",
        ""
    ]
}
