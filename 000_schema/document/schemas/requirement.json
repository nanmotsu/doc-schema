{
    "key": "requirement",
    "label": "Requirement",
    "prefix": "REQ",
    "idExample": "REQ-2026-001",
    "dirParts": [ "docs", "10_specs", "requirements" ],
    "numbering": "year_seq",
    "defaultStatus": "draft",
    "statuses": [
        { "code": "draft", "label": "draft" },
        { "code": "review", "label": "review" },
        { "code": "approved", "label": "approved" },
        { "code": "active", "label": "active" },
        { "code": "deprecated", "label": "deprecated" },
        { "code": "closed", "label": "closed" }
    ],
    "schema": {
        "required": [ "id", "title", "type", "status", "visibility" ],
        "properties": {
            "id": { "type": "string", "pattern": "^REQ-\\d{4}-\\d{3}$" },
            "title": { "type": "string" },
            "type": { "type": "string", "enum": [ "requirement" ] },
            "status": { "type": "string", "enum": [ "draft", "review", "approved", "active", "deprecated", "closed" ] },
            "version": { "type": "string" },
            "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "owner": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "specifications": { "type": "array", "items": { "type": "string", "pattern": "^(\\[\\[[^\\]\\n]+\\]\\]|SPEC-\\d{4}-\\d{3})$" } },
            "visibility": { "type": "string", "enum": [ "internal", "customer", "partial", "confidential" ] }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "title: {{title}}",
        "type: requirement",
        "status: {{status}}",
        "version: 0.1.0",
        "created_at: {{date}}",
        "updated_at: {{date}}",
        "owner:",
        "tags:",
        "  - ",
        "specifications:",
        "  - ",
        "visibility: internal",
        "---",
        "",
        "# {{id}}_{{title}}",
        "",
        "## 1. 目的",
        "- 何のために必要か",
        "",
        "## 2. 背景",
        "- 現状の課題や経緯",
        "",
        "## 3. 要求内容",
        "- 必須 / 任意 / 除外を分けて書く",
        "",
        "## 4. 非機能制約",
        "- 性能 / 運用 / セキュリティ / 保守",
        "",
        "## 5. 受入条件",
        "- 何を満たせば完了か",
        ""
    ]
}
