{
    "key": "test_case",
    "label": "Test Case",
    "prefix": "TEST",
    "idExample": "TEST-2026-001",
    "dirParts": [ "docs", "20_tests", "master_test_cases" ],
    "numbering": "year_seq",
    "defaultStatus": "draft",
    "statuses": [
        { "code": "draft", "label": "draft" },
        { "code": "review", "label": "review" },
        { "code": "approved", "label": "approved" },
        { "code": "active", "label": "active" },
        { "code": "deprecated", "label": "deprecated" },
        { "code": "closed", "label": "closed" }
    ],
    "schema": {
        "required": [ "id", "title", "type", "status", "visibility" ],
        "properties": {
            "id": { "type": "string", "pattern": "^TEST-\\d{4}-\\d{3}$" },
            "title": { "type": "string" },
            "type": { "type": "string", "enum": [ "test_case" ] },
            "status": { "type": "string", "enum": [ "draft", "review", "approved", "active", "deprecated", "closed" ] },
            "version": { "type": "string" },
            "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "owner": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "releases": { "type": "array", "items": { "type": "string", "pattern": "^(\\[\\[[^\\]\\n]+\\]\\]|RELEASE-\\d{4}-\\d{3})$" } },
            "visibility": { "type": "string", "enum": [ "internal", "customer", "partial", "confidential" ] }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "title: {{title}}",
        "type: test_case",
        "status: {{status}}",
        "version: 0.1.0",
        "created_at: {{date}}",
        "updated_at: {{date}}",
        "owner:",
        "tags:",
        "  - ",
        "releases:",
        "  - ",
        "visibility: internal",
        "---",
        "",
        "# {{id}}_{{title}}",
        "",
        "## 1. 目的",
        "- このテストで何を確認するか",
        "",
        "## 2. 関連仕様",
        "- Requirement / Specification / Change など",
        "",
        "## 3. 前提条件",
        "- 環境、データ、権限、事前状態",
        "",
        "## 4. 手順",
        "- 1 操作 1 行で書く",
        "",
        "| No | 操作 | 入力値 | 期待結果 |",
        "|---:|---|---|---|",
        "",
        "## 5. 確認観点",
        "- 正常系 / 異常系 / 境界値",
        "",
        "## 6. 実施結果",
        "- pass / fail / pending",
        "",
        "## 7. 証跡",
        "- 画像、ログ、出力物など",
        ""
    ]
}
