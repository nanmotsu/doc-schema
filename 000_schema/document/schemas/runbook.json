{
    "key": "runbook",
    "label": "Runbook",
    "prefix": "RUNBOOK",
    "idExample": "RUNBOOK-2026-001",
    "dirParts": [ "docs", "30_operations", "runbook" ],
    "numbering": "year_seq",
    "defaultStatus": "draft",
    "statuses": [
        { "code": "draft", "label": "draft" },
        { "code": "review", "label": "review" },
        { "code": "approved", "label": "approved" },
        { "code": "active", "label": "active" },
        { "code": "deprecated", "label": "deprecated" },
        { "code": "closed", "label": "closed" }
    ],
    "schema": {
        "required": [ "id", "title", "type", "status", "visibility" ],
        "properties": {
            "id": { "type": "string", "pattern": "^RUNBOOK-\\d{4}-\\d{3}$" },
            "title": { "type": "string" },
            "type": { "type": "string", "enum": [ "runbook" ] },
            "status": { "type": "string", "enum": [ "draft", "review", "approved", "active", "deprecated", "closed" ] },
            "version": { "type": "string" },
            "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "owner": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "releases": { "type": "array", "items": { "type": "string", "pattern": "^(\\[\\[[^\\]\\n]+\\]\\]|RELEASE-\\d{4}-\\d{3})$" } },
            "visibility": { "type": "string", "enum": [ "internal", "customer", "partial", "confidential" ] }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "title: {{title}}",
        "type: runbook",
        "status: {{status}}",
        "version: 0.1.0",
        "created_at: {{date}}",
        "updated_at: {{date}}",
        "owner:",
        "tags:",
        "  - ",
        "releases:",
        "  - ",
        "visibility: internal",
        "---",
        "",
        "# Runbook名",
        "",
        "## 1. 目的",
        "",
        "## 2. 利用タイミング",
        "",
        "## 3. 前提条件",
        "",
        "## 4. 手順",
        "",
        "## 5. 正常確認",
        "",
        "## 6. 異常時対応",
        "",
        "## 7. ロールバック",
        "",
        "## 8. 注意事項",
        ""
    ]
}
