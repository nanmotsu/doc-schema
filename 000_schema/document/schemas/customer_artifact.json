{
    "key": "customer_artifact",
    "label": "Customer Artifact",
    "prefix": "CUST",
    "idExample": "CUST-2026-001",
    "dirParts": [ "docs", "40_customer_outputs" ],
    "numbering": "year_seq",
    "defaultStatus": "draft",
    "statuses": [
        { "code": "draft", "label": "draft" },
        { "code": "review", "label": "review" },
        { "code": "approved", "label": "approved" },
        { "code": "active", "label": "active" },
        { "code": "deprecated", "label": "deprecated" },
        { "code": "closed", "label": "closed" }
    ],
    "schema": {
        "required": [ "id", "title", "type", "status", "visibility" ],
        "properties": {
            "id": { "type": "string", "pattern": "^CUST-\\d{4}-\\d{3}$" },
            "title": { "type": "string" },
            "type": { "type": "string", "enum": [ "customer_artifact" ] },
            "artifact_type": { "type": "string" },
            "status": { "type": "string", "enum": [ "draft", "review", "approved", "active", "deprecated", "closed" ] },
            "version": { "type": "string" },
            "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "owner": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "releases": { "type": "array", "items": { "type": "string", "pattern": "^(\\[\\[[^\\]\\n]+\\]\\]|RELEASE-\\d{4}-\\d{3})$" } },
            "visibility": { "type": "string", "enum": [ "internal", "customer", "partial", "confidential" ] }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "title: {{title}}",
        "type: customer_artifact",
        "artifact_type:",
        "status: {{status}}",
        "version: 0.1.0",
        "created_at: {{date}}",
        "updated_at: {{date}}",
        "owner:",
        "tags:",
        "  - ",
        "releases:",
        "  - ",
        "visibility: customer",
        "---",
        "",
        "# 客先成果物名",
        "",
        "## 1. 成果物の種類",
        "",
        "## 2. 掲載先",
        "",
        "## 3. 説明内容",
        "",
        "## 4. 関連仕様",
        "",
        "## 5. 関連図・画面",
        "",
        "## 6. 非掲載・一部掲載の理由",
        ""
    ]
}
