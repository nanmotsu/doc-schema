{
    "key": "specification",
    "label": "Specification",
    "prefix": "SPEC",
    "idExample": "SPEC-2026-001",
    "dirParts": [ "docs", "10_specs", "product_baseline" ],
    "numbering": "year_seq",
    "defaultStatus": "draft",
    "statuses": [
        { "code": "draft", "label": "draft" },
        { "code": "review", "label": "review" },
        { "code": "approved", "label": "approved" },
        { "code": "active", "label": "active" },
        { "code": "deprecated", "label": "deprecated" },
        { "code": "closed", "label": "closed" }
    ],
    "schema": {
        "required": [ "id", "title", "type", "status", "visibility" ],
        "properties": {
            "id": { "type": "string", "pattern": "^SPEC-\\d{4}-\\d{3}$" },
            "title": { "type": "string" },
            "type": { "type": "string", "enum": [ "specification" ] },
            "status": { "type": "string", "enum": [ "draft", "review", "approved", "active", "deprecated", "closed" ] },
            "version": { "type": "string" },
            "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "owner": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "tests": { "type": "array", "items": { "type": "string", "pattern": "^(\\[\\[[^\\]\\n]+\\]\\]|TEST-\\d{4}-\\d{3})$" } },
            "visibility": { "type": "string", "enum": [ "internal", "customer", "partial", "confidential" ] }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "title: {{title}}",
        "type: specification",
        "status: {{status}}",
        "version: 0.1.0",
        "created_at: {{date}}",
        "updated_at: {{date}}",
        "owner:",
        "tags:",
        "  - ",
        "tests:",
        "  - ",
        "visibility: internal",
        "---",
        "",
        "# {{id}}_{{title}}",
        "",
        "## 1. 概要",
        "- この文書が何を定義するか",
        "",
        "## 2. 対象範囲",
        "- 対象 / 非対象を明確にする",
        "",
        "## 3. 業務ルール",
        "- 業務上の判断基準や制約",
        "",
        "## 4. 機能仕様",
        "- 画面 / API / バッチ / 権限 / ログ",
        "",
        "## 5. 入力",
        "- 入力値、前提、検証条件",
        "",
        "## 6. 出力",
        "- 期待される結果や出力物",
        "",
        "## 7. エラー・例外",
        "- 失敗時の挙動やメッセージ",
        "",
        "## 8. 権限",
        "- 誰が何をできるか",
        "",
        "## 9. 非機能・使用性",
        "- 性能 / 保守 / 運用 / UI",
        "",
        "## 10. 受入条件",
        "- テスト観点に落ちる条件",
        "",
        "## 11. 補足",
        "- 参考情報や未確定事項",
        ""
    ]
}
