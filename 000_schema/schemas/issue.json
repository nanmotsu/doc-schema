{
    "key": "issue",
    "label": "Issue（問題）",
    "prefix": "ISSUE",
    "idExample": "ISSUE-001",
    "dirParts": [ "internal", "4_issues" ],
    "numbering": "seq",
    "defaultStatus": "OPEN",
    "statuses": [
        { "code": "UNFINISHED", "label": "未整理" },
        { "code": "OPEN", "label": "問題発見" },
        { "code": "INVESTIGATING", "label": "調査中" },
        { "code": "RESOLVED", "label": "解決済み" },
        { "code": "CLOSED", "label": "完全終了" }
    ],
    "schema": {
        "required": [ "id", "status" ],
        "properties": {
            "id": { "type": "string", "pattern": "^ISSUE-\\d{3}$" },
            "status": { "type": "string", "enum": [ "UNFINISHED", "OPEN", "INVESTIGATING", "RESOLVED", "CLOSED" ] },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
    },
    "body": [
        "---",
        "id: {{id}}",
        "tags:",
        "  - ISSUE",
        "status: {{status}}",
        "updated_at: {{date}}",
        "---",
        "",
        "# {{id}}_{{title}}",
        "",
        "## 問題概要",
        "- 何が問題か",
        "",
        "## 現象",
        "- 具体的な挙動",
        "",
        "## 期待される状態",
        "- 本来どうあるべきか",
        "",
        "## 影響範囲",
        "- ユーザー:",
        "- システム:",
        "- 業務:",
        "",
        "## 発生条件",
        "- 再現条件:",
        "",
        "## 原因仮説",
        "- ",
        "",
        "## 調査内容",
        "- ",
        "",
        "## 原因",
        "- 確定した原因（RESOLVED時に記載）",
        "",
        "## 対応方針",
        "- 修正",
        "- 回避",
        "- 仕様変更",
        "",
        "## 解決方法",
        "- ",
        "",
        "## 再発防止",
        "- ",
        "",
        "## 要件化の必要性",
        "- 必要 / 不要",
        "",
        "## 内容",
        "- ",
        "",
        "## 関連リンク",
        "- ",
        ""
    ]
}
