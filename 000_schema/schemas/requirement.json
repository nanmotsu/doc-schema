{
    "key": "requirement",
    "label": "Requirement（要件）",
    "prefix": "REQ",
    "idExample": "REQ-001",
    "dirParts": [ "external", "1_requirements" ],
    "numbering": "seq",
    "defaultStatus": "DRAFT",
    "statuses": [
        { "code": "UNFINISHED", "label": "未整理" },
        { "code": "DRAFT", "label": "曖昧・合意前" },
        { "code": "ACTIVE", "label": "合意済み" },
        { "code": "DEPRECATED", "label": "不要" }
    ],
    "schema": {
        "required": [ "id", "status" ],
        "properties": {
            "id": { "type": "string", "pattern": "^REQ-\\d{3}$" },
            "status": { "type": "string", "enum": [ "UNFINISHED", "DRAFT", "ACTIVE", "DEPRECATED" ] },
            "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
    },
